    end

    function Window:SaveConfig(name)
        if not HasFileAPI() then return false, "file API indisponível" end
        name = name or "default"
        local ok, err = pcall(function()
            if typeof(makefolder) == "function" and typeof(isfolder) == "function" then
                if not isfolder(self.Folder) then
                    makefolder(self.Folder)
                end
            end
            local encoded = HttpService:JSONEncode(self.Flags)
            writefile(self.Folder .. "/" .. name .. ".json", encoded)
        end)
        return ok, err
    end

    function Window:LoadConfig(name)
        if not HasFileAPI() then return false, "file API indisponível" end
        name = name or "default"
        local path = self.Folder .. "/" .. name .. ".json"
        if not isfile(path) then return false, "config não encontrada" end
        local ok, result = pcall(function()
            local data = HttpService:JSONDecode(readfile(path))
            for flag, value in pairs(data) do
                self.Flags[flag] = value
                local element = self.Elements[flag]
                if element and element.Set then
                    element:Set(value)
                end
            end
        end)
        return ok, result
    end

    function Window:_Register(flag, element, default)
        if not flag then return end
        self.Elements[flag] = element
        if self.Flags[flag] == nil then
            self.Flags[flag] = default
        end
    end

