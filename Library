                PlaceholderColor3 = Theme.SubText,
                Text = opt.Default or "",
                TextColor3 = Theme.Text,
                TextSize = responsive.FontSize * 0.95,
                TextXAlignment = Enum.TextXAlignment.Left,
                ClearTextOnFocus = false,
                Parent = Holder,
            })

            Box.FocusLost:Connect(function(enterPressed)
                if opt.Flag then Window.Flags[opt.Flag] = Box.Text end
                SafeCallback(opt.Callback, Box.Text, enterPressed)
            end)

            local API = { Instance = Box }
            function API:Set(v) Box.Text = tostring(v) end
            function API:Get() return Box.Text end

            Window:_Register(opt.Flag, API, Box.Text)
            return API
        end

        function TabAPI:CreateKeybind(opt)
            opt = opt or {}
            local bound = opt.Default or Enum.KeyCode.Unknown
            local listening = false

            local Holder = Create("Frame", {
                Size = UDim2.new(1, 0, 0, responsive.FontSize * 3.2),
                BackgroundColor3 = Theme.Element,
                BackgroundTransparency = 0.5,
                Parent = Page,
            })
            Round(Holder, Theme.CornerSmall)

            Create("TextLabel", {
                Size = UDim2.new(1, -responsive.FontSize * 8, 1, 0),
                Position = UDim2.new(0, responsive.Padding, 0, 0),
                BackgroundTransparency = 1,
                Font = Enum.Font.GothamBold,
                Text = opt.Title or "Keybind",
                TextColor3 = Theme.Text,
                TextSize = responsive.FontSize * 0.95,
                TextXAlignment = Enum.TextXAlignment.Left,
                Parent = Holder,
            })

            local KeyBtn = Create("TextButton", {
                Size = UDim2.fromOffset(responsive.FontSize * 6, responsive.FontSize * 2.2),
                Position = UDim2.new(1, -responsive.FontSize * 6.5, 0.5, -responsive.FontSize * 1.1),
                BackgroundColor3 = Theme.Sidebar,
                BackgroundTransparency = 0.5,
                Font = Enum.Font.Gotham,
                Text = bound == Enum.KeyCode.Unknown and "Nenhuma" or bound.Name,
                TextColor3 = Theme.SubText,
                TextSize = responsive.FontSize * 0.85,
                AutoButtonColor = false,
                Parent = Holder,
            })
            Round(KeyBtn, Theme.CornerSmall)

            local API = {}

            KeyBtn.MouseButton1Click:Connect(function()
                listening = true
                KeyBtn.Text = "..."
                Tween(KeyBtn, { BackgroundColor3 = Theme.Accent }, 0.2)
            end)

            UserInputService.InputBegan:Connect(function(input, gameProcessed)
                if listening and input.UserInputType == Enum.UserInputType.Keyboard then
                    listening = false
                    bound = input.KeyCode
                    KeyBtn.Text = bound.Name
                    Tween(KeyBtn, { BackgroundColor3 = Theme.Sidebar }, 0.2)
                    if opt.Flag then Window.Flags[opt.Flag] = bound.Name end
                    return
                end
                if gameProcessed then return end
                if not listening and bound ~= Enum.KeyCode.Unknown and input.KeyCode == bound then
                    SafeCallback(opt.Callback, bound)
                end
            end)

            function API:Set(keyCode)
                if typeof(keyCode) == "string" then
                    keyCode = Enum.KeyCode[keyCode] or Enum.KeyCode.Unknown
                end
                bound = keyCode
                KeyBtn.Text = bound == Enum.KeyCode.Unknown and "Nenhuma" or bound.Name
            end
            function API:Get() return bound end

            Window:_Register(opt.Flag, API, bound.Name)
            return API
        end

        function TabAPI:CreateColorPicker(opt)
            opt = opt or {}
            local color = opt.Default or Color3.fromRGB(255, 255, 255)
            local open = false
            local h, s, v = color:ToHSV()

            local Holder = Create("Frame", {
                Size = UDim2.new(1, 0, 0, responsive.FontSize * 3.2),
                BackgroundColor3 = Theme.Element,
                BackgroundTransparency = 0.5,
                ClipsDescendants = true,
                Parent = Page,
            })
            Round(Holder, Theme.CornerSmall)

            local Head = Create("TextButton", {
                Size = UDim2.new(1, 0, 0, responsive.FontSize * 3.2),
                BackgroundTransparency = 1,
                Text = "",
                AutoButtonColor = false,
                Parent = Holder,
            })

            Create("TextLabel", {
                Size = UDim2.new(1, -responsive.FontSize * 5, 1, 0),
                Position = UDim2.new(0, responsive.Padding, 0, 0),
                BackgroundTransparency = 1,
                Font = Enum.Font.GothamBold,
                Text = opt.Title or "Cor",
                TextColor3 = Theme.Text,
                TextSize = responsive.FontSize * 0.95,
                TextXAlignment = Enum.TextXAlignment.Left,
                Parent = Head,
            })

            local Preview = Create("Frame", {
                Size = UDim2.fromOffset(responsive.FontSize * 2.4, responsive.FontSize * 1.8),
                Position = UDim2.new(1, -responsive.FontSize * 3.2, 0.5, -responsive.FontSize * 0.9),
                BackgroundColor3 = color,
                Parent = Head,
            })
            Round(Preview, Theme.CornerSmall)
            Stroke(Preview, Theme.Stroke, 1, 0.3)

            local Body = Create("Frame", {
                Size = UDim2.new(1, -responsive.Padding * 2, 0, responsive.FontSize * 8),
                Position = UDim2.new(0, responsive.Padding, 0, responsive.FontSize * 3.6),
                BackgroundTransparency = 1,
                Parent = Holder,
            })

            local SVBox = Create("ImageLabel", {
                Size = UDim2.new(1, 0, 0, responsive.FontSize * 5),
                BackgroundColor3 = Color3.fromHSV(h, 1, 1),
                Image = "rbxassetid://4155801252",
                Parent = Body,
            })
            Round(SVBox, Theme.CornerSmall)

            local SVCursor = Create("Frame", {
                Size = UDim2.fromOffset(responsive.FontSize * 0.7, responsive.FontSize * 0.7),
                AnchorPoint = Vector2.new(0.5, 0.5),
                Position = UDim2.new(s, 0, 1 - v, 0),
                BackgroundColor3 = Color3.new(1, 1, 1),
                BorderSizePixel = 0,
                Parent = SVBox,
            })
            Round(SVCursor, UDim.new(1, 0))
            Stroke(SVCursor, Color3.new(0, 0, 0), 1, 0.5)

            local HueBar = Create("Frame", {
                Size = UDim2.new(1, 0, 0, responsive.FontSize * 1.2),
                Position = UDim2.new(0, 0, 0, responsive.FontSize * 5.6),
                Parent = Body,
            })
            Round(HueBar, Theme.CornerSmall)
            Create("UIGradient", {
                Color = ColorSequence.new({
                    ColorSequenceKeypoint.new(0.00, Color3.fromRGB(255, 0, 0)),
                    ColorSequenceKeypoint.new(0.17, Color3.fromRGB(255, 255, 0)),
                    ColorSequenceKeypoint.new(0.33, Color3.fromRGB(0, 255, 0)),
                    ColorSequenceKeypoint.new(0.50, Color3.fromRGB(0, 255, 255)),
                    ColorSequenceKeypoint.new(0.67, Color3.fromRGB(0, 0, 255)),
                    ColorSequenceKeypoint.new(0.83, Color3.fromRGB(255, 0, 255)),
                    ColorSequenceKeypoint.new(1.00, Color3.fromRGB(255, 0, 0)),
                }),
                Parent = HueBar,
            })

            local HueCursor = Create("Frame", {
                Size = UDim2.fromOffset(4, responsive.FontSize * 1.2),
                Position = UDim2.new(h, -2, 0, 0),
                BackgroundColor3 = Color3.new(1, 1, 1),
                BorderSizePixel = 0,
                Parent = HueBar,
            })

            local API = {}

            local function UpdateColor(fireCallback)
                color = Color3.fromHSV(h, s, v)
                Preview.BackgroundColor3 = color
                SVBox.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
                if opt.Flag then Window.Flags[opt.Flag] = { h, s, v } end
                if fireCallback then SafeCallback(opt.Callback, color) end
            end

            local draggingSV, draggingHue = false, false

            SVBox.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    draggingSV = true
                end
            end)
            HueBar.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    draggingHue = true
                end
            end)
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    draggingSV = false
                    draggingHue = false
                end
            end)
            UserInputService.InputChanged:Connect(function(input)
                if input.UserInputType ~= Enum.UserInputType.MouseMovement and input.UserInputType ~= Enum.UserInputType.Touch then return end
                if draggingSV then
                    local relX = math.clamp((input.Position.X - SVBox.AbsolutePosition.X) / SVBox.AbsoluteSize.X, 0, 1)
                    local relY = math.clamp((input.Position.Y - SVBox.AbsolutePosition.Y) / SVBox.AbsoluteSize.Y, 0, 1)
                    s, v = relX, 1 - relY
                    SVCursor.Position = UDim2.new(relX, 0, relY, 0)
                    UpdateColor(true)
                elseif draggingHue then
                    local relX = math.clamp((input.Position.X - HueBar.AbsolutePosition.X) / HueBar.AbsoluteSize.X, 0, 1)
                    h = relX
                    HueCursor.Position = UDim2.new(relX, -2, 0, 0)
                    UpdateColor(true)
                end
            end)

            Head.MouseButton1Click:Connect(function()
                open = not open
                Tween(Holder, { Size = UDim2.new(1, 0, 0, open and responsive.FontSize * 12 or responsive.FontSize * 3.2) }, 0.3)
            end)

            function API:Set(c)
                color = c
                h, s, v = c:ToHSV()
                SVCursor.Position = UDim2.new(s, 0, 1 - v, 0)
                HueCursor.Position = UDim2.new(h, -2, 0, 0)
                UpdateColor(false)
            end
            function API:Get() return color end

            Window:_Register(opt.Flag, API, { h, s, v })
            return API
        end

        return TabAPI
    end

    -- Notificação de boas-vindas
    Window:Notify({
        Title = "✨ " .. title,
        Content = IsMobile() and "📱 Modo Mobile ativado!" or "🖥️ Modo PC ativado!",
        Type = "Success",
        Duration = 3
    })

    return Window
end

return Library