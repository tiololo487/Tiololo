                for value, btn in pairs(optionButtons) do
                    if value == selected then
                        Tween(btn, { BackgroundColor3 = Theme.Accent }, 0.2)
                        Tween(btn.TextLabel, { TextColor3 = Theme.Text }, 0.2)
                    else
                        Tween(btn, { BackgroundColor3 = Theme.ElementHover }, 0.2)
