local function ResolveTheme(themeConfig)
    local base = ThemePresets.Dark
    if type(themeConfig) == "string" and ThemePresets[themeConfig] then
        base = ThemePresets[themeConfig]
    end
    local Theme = {}
    for k, v in pairs(base) do Theme[k] = v end
    if type(themeConfig) == "table" then
        for k, v in pairs(themeConfig) do Theme[k] = v end
    end
    return Theme
end

