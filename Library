                Text = opt.Title or "Slider",
                TextColor3 = Theme.Text,
                TextSize = responsive.FontSize * 0.95,
                TextXAlignment = Enum.TextXAlignment.Left,
                Parent = Holder,
            })

            local ValueLabel = Create("TextLabel", {
                Size = UDim2.fromOffset(responsive.FontSize * 4.5, responsive.FontSize * 1.4),
                Position = UDim2.new(1, -responsive.FontSize * 4.5, 0, responsive.Padding * 0.3),
                BackgroundTransparency = 1,
                Font = Enum.Font.Gotham,
                Text = tostring(value),
                TextColor3 = Theme.Accent,
                TextSize = responsive.FontSize * 0.95,
                TextXAlignment = Enum.TextXAlignment.Right,
                Parent = Holder,
            })

            local Track = Create("Frame", {
                Size = UDim2.new(1, -responsive.Padding * 2, 0, responsive.FontSize * 0.5),
                Position = UDim2.new(0, responsive.Padding, 0, responsive.FontSize * 2.6),
                BackgroundColor3 = Theme.Sidebar,
                BackgroundTransparency = 0.5,
                Parent = Holder,
            })
            Round(Track, UDim.new(1, 0))

            local Fill = Create("Frame", {
                Size = UDim2.new((value - min) / (max - min), 0, 1, 0),
                BackgroundColor3 = Theme.Accent,
                Parent = Track,
            })
            Round(Fill, UDim.new(1, 0))

            -- Knob do slider
            local Knob = Create("Frame", {
                Size = UDim2.fromOffset(responsive.FontSize * 1.4, responsive.FontSize * 1.4),
                Position = UDim2.new((value - min) / (max - min), -responsive.FontSize * 0.7, 0.5, -responsive.FontSize * 0.7),
                BackgroundColor3 = Theme.Accent,
                Parent = Holder,
                ZIndex = 2,
            })
            Round(Knob, UDim.new(1, 0))
            Stroke(Knob, Theme.Stroke, 1, 0.3)

            local API = {}
            local dragging = false

            local function FormatValue(v)
                if decimals > 0 then
                    return string.format("%." .. decimals .. "f", v)
                end
                return tostring(math.floor(v))
            end

            local function ApplyValue(v, fireCallback)
                value = math.clamp(Round2(v, decimals), min, max)
                local rel = (max > min) and (value - min) / (max - min) or 0
                Fill.Size = UDim2.new(rel, 0, 1, 0)
                Knob.Position = UDim2.new(rel, -responsive.FontSize * 0.7, 0.5, -responsive.FontSize * 0.7)
                ValueLabel.Text = FormatValue(value)
                if opt.Flag then Window.Flags[opt.Flag] = value end
                if fireCallback then SafeCallback(opt.Callback, value) end
            end

            local function UpdateFromInputX(x)
                local rel = math.clamp((x - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
                local raw = min + (max - min) * rel
                raw = math.floor(raw / step + 0.5) * step
                ApplyValue(raw, true)
            end

            Track.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = true
                    UpdateFromInputX(input.Position.X)
                end
            end)
            
            Knob.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = true
                end
            end)
            
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = false
                end
            end)
            
            UserInputService.InputChanged:Connect(function(input)
                if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                    UpdateFromInputX(input.Position.X)
                end
            end)

            function API:Set(v) ApplyValue(v, false) end
            function API:Get() return value end

            Window:_Register(opt.Flag, API, value)
            return API
        end

