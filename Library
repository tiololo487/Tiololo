-- UTILIDADES PREMIUM
----------------------------------------------------------------
local function Create(class, props, children)
    local inst = Instance.new(class)
    for prop, value in pairs(props or {}) do
        inst[prop] = value
    end
    for _, child in ipairs(children or {}) do
        child.Parent = inst
    end
    return inst
end

local function Round(parent, radius)
    local corner = Instance.new("UICorner")
    corner.CornerRadius = radius or UDim.new(0, 14)
    corner.Parent = parent
    return corner
end

local function Stroke(parent, color, thickness, transparency)
    local stroke = Instance.new("UIStroke")
    stroke.Color = color or Color3.fromRGB(45, 45, 60)
    stroke.Thickness = thickness or 1
    stroke.Transparency = transparency or 0
    stroke.Parent = parent
    return stroke
end

local function Padding(parent, all)
    local pad = Instance.new("UIPadding")
    pad.PaddingLeft = UDim.new(0, all or 12)
    pad.PaddingRight = UDim.new(0, all or 12)
    pad.PaddingTop = UDim.new(0, all or 12)
    pad.PaddingBottom = UDim.new(0, all or 12)
    pad.Parent = parent
    return pad
end

local function Tween(obj, props, time, style, dir)
    if not obj or not obj.Parent then return nil end
    local tween = TweenService:Create(
        obj,
        TweenInfo.new(time or 0.3, style or Enum.EasingStyle.Quad, dir or Enum.EasingDirection.Out),
        props
    )
    tween:Play()
    return tween
end

local function TweenBounce(obj, props, time)
    if not obj or not obj.Parent then return nil end
    local tween = TweenService:Create(
        obj,
        TweenInfo.new(time or 0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
        props
    )
    tween:Play()
    return tween
end

local function SafeCallback(fn, ...)
    if not fn then return end
    local args = { ... }
    task.spawn(function()
        local ok, err = pcall(fn, table.unpack(args))
        if not ok then
            warn("[BlackUI] Erro em callback: " .. tostring(err))
        end
    end)
end

-- DRAG CORRIGIDO - Versão Ultra Estável
local function MakeDraggable(dragHandle, target)
    local dragging = false
    local dragStart, startPos
    local connections = {}
    local bounds = {}

    -- Obtém limites da tela
    local function UpdateBounds()
        local viewport = workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize
        if viewport then
            local sizeX, sizeY = target.AbsoluteSize.X, target.AbsoluteSize.Y
            bounds.minX = 0
            bounds.maxX = viewport.X - sizeX
            bounds.minY = 0
            bounds.maxY = viewport.Y - sizeY
        end
    end

    local function update(input)
        if not startPos then return end
        
        local delta = input.Position - dragStart
        local newX = startPos.X.Offset + delta.X
        local newY = startPos.Y.Offset + delta.Y

        -- Atualiza limites dinamicamente
        UpdateBounds()
        
        -- Clamp com limites suaves
        newX = math.clamp(newX, bounds.minX or -100, bounds.maxX or 100)
        newY = math.clamp(newY, bounds.minY or 0, bounds.maxY or 100)

        target.Position = UDim2.new(startPos.X.Scale, newX, startPos.Y.Scale, newY)
    end

    local function onInputBegan(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or 
           input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = target.Position
            UpdateBounds()
        end
    end

    local function onInputChanged(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or 
                         input.UserInputType == Enum.UserInputType.Touch) then
            update(input)
        end
    end

    local function onInputEnded(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or 
           input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end

    connections[#connections + 1] = dragHandle.InputBegan:Connect(onInputBegan)
    connections[#connections + 1] = UserInputService.InputChanged:Connect(onInputChanged)
    connections[#connections + 1] = UserInputService.InputEnded:Connect(onInputEnded)

    -- Reconecta quando a janela for redimensionada
    connections[#connections + 1] = target:GetPropertyChangedSignal("AbsoluteSize"):Connect(UpdateBounds)

    return function()
        for _, conn in ipairs(connections) do
            conn:Disconnect()
        end
        table.clear(connections)
    end
end

local function ResolveIcon(icon)
    if not icon or icon == "" then return nil end
    if typeof(icon) == "number" then
        return "rbxassetid://" .. tostring(icon)
    end
    if typeof(icon) == "string" then
        if icon:match("^rbxassetid://") or icon:match("^rbxasset://") or icon:match("^http") then
            return icon
        end
        if tonumber(icon) then
            return "rbxassetid://" .. icon
        end
    end
    return nil
end

local function Round2(value, decimals)
    local mult = 10 ^ (decimals or 0)
    return math.floor(value * mult + 0.5) / mult
end

local function CreateGlow(parent, color, size)
    local glow = Create("ImageLabel", {
        BackgroundTransparency = 1,
        Position = UDim2.new(0.5, 0, 0.5, 0),
        Size = UDim2.fromOffset(size or 200, size or 200),
        AnchorPoint = Vector2.new(0.5, 0.5),
        Image = "rbxassetid://5028857089",
        ImageColor3 = color or Color3.fromRGB(120, 80, 255),
        ImageTransparency = 0.7,
        ScaleType = Enum.ScaleType.Fit,
        ZIndex = -1,
        Parent = parent,
    })
    return glow
end

