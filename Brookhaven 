-- ============================================

local function flingWithCouch(targetPlayer)
    if not targetPlayer then return end
    local localChar = LocalPlayer.Character
    if not localChar then return end
    
    local localHRP = localChar:FindFirstChild("HumanoidRootPart")
    local targetHRP = getHRP(targetPlayer)
    
    if not localHRP or not targetHRP then return end
    
    local re = getRE()
    if re then
        local clearTools = re:FindFirstChild("1Clea1rTool1s")
        if clearTools then
            clearTools:FireServer("ClearAllTools")
        end
    end
    
    task.wait(0.3)
    
    if re then
        local toolEvent = re:FindFirstChild("1Too1l")
        if toolEvent then
            toolEvent:InvokeServer("PickingTools", "Couch")
        end
    end
    
    local couch = LocalPlayer.Backpack:FindFirstChildOfClass("Tool")
    if couch and couch.Name == "Couch" then
        couch.Parent = localChar
    end
    
    Workspace.FallenPartsDestroyHeight = -math.huge
    
    local bv = Instance.new("BodyVelocity")
    bv.Velocity = Vector3.new(900000000, 900000000, 900000000)
    bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    bv.Parent = localHRP
    
    local humanoid = localChar:FindFirstChildOfClass("Humanoid")
    if humanoid then
        humanoid:SetStateEnabled(Enum.HumanoidStateType.Seated, false)
        humanoid.PlatformStand = false
    end
    
    local angle = 0
    for i = 1, 15 do
        if not targetHRP or not targetHRP.Parent then break end
        if localHRP.Position.Y >= 70000 then break end
        
        angle = angle + 30
        localHRP.CFrame = CFrame.new(targetHRP.Position + Vector3.new(0, 1, 0)) * CFrame.Angles(math.rad(angle), 0, 0)
        localHRP.Velocity = Vector3.new(900000000, 900000000, 900000000)
        localHRP.RotVelocity = Vector3.new(900000000, 900000000, 900000000)
        
        task.wait(0.05)
    end
    
    bv:Destroy()
    
    if humanoid then
        humanoid:SetStateEnabled(Enum.HumanoidStateType.Seated, true)
        humanoid.PlatformStand = false
    end
    
    if re then
        local clearTools = re:FindFirstChild("1Clea1rTool1s")
        if clearTools then
            clearTools:FireServer("ClearAllTools")
        end
    end
end

local function flingWithBall(targetPlayer)
    if not targetPlayer then return end
    local localChar = LocalPlayer.Character
    if not localChar then return end
    
    local localHRP = localChar:FindFirstChild("HumanoidRootPart")
    local targetHRP = getHRP(targetPlayer)
    
    if not localHRP or not targetHRP then return end
    
    local re = getRE()
    if re then
        local toolEvent = re:FindFirstChild("1Too1l")
        if toolEvent then
            toolEvent:InvokeServer("PickingTools", "SoccerBall")
        end
    end
    
    task.wait(0.5)
    
    local ball = LocalPlayer.Backpack:FindFirstChild("SoccerBall")
    if ball then
        ball.Parent = localChar
    end
    
    local soccerBall = Workspace:FindFirstChild("Soccer" .. LocalPlayer.Name)
    if soccerBall then
        soccerBall.Name = "ShieldBall"
        soccerBall.CanCollide = false
        soccerBall.Massless = true
        soccerBall.CustomPhysicalProperties = PhysicalProperties.new(0.0001, 0, 0)
        
        local bv = Instance.new("BodyVelocity")
        bv.Velocity = Vector3.new(900000000, 900000000, 900000000)
        bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        bv.Parent = soccerBall
        
        task.wait(2)
        bv:Destroy()
    end
end

local function flingWithBoat(targetPlayer)
    if not targetPlayer then return end
    -- Implementação simplificada
    flingWithCouch(targetPlayer)
end

local function bringPlayer(targetPlayer)
    if not targetPlayer then return end
    local localChar = LocalPlayer.Character
    if not localChar then return end
    
    local localHRP = localChar:FindFirstChild("HumanoidRootPart")
    local targetHRP = getHRP(targetPlayer)
    
    if not localHRP or not targetHRP then return end
    
    targetHRP.CFrame = localHRP.CFrame * CFrame.new(0, 0, -3)
end

local function goToPlayer(targetPlayer)
    if not targetPlayer then return end
    local localChar = LocalPlayer.Character
    if not localChar then return end
    
    local localHRP = localChar:FindFirstChild("HumanoidRootPart")
    local targetHRP = getHRP(targetPlayer)
    
    if not localHRP or not targetHRP then return end
    
    localHRP.CFrame = targetHRP.CFrame * CFrame.new(0, 0, 3)
end

local function killPlayer(targetPlayer)
