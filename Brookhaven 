local function rgbLoop(eventName, fireMethod)
    task.spawn(function()
        local re = getRE()
        while getgenv().LyraHub.AntiToolSingleActive do
            if re then
                local colorEvent = re:FindFirstChild(eventName)
                if colorEvent then
                    local color = Color3.fromHSV(tick() * (getgenv().LyraHub.rgbSpeed or 1) % 5 / 5, 1, 1)
                    if fireMethod == "FireServer" then
                        colorEvent:FireServer(color)
                    elseif fireMethod == "InvokeServer" then
                        colorEvent:InvokeServer(color)
                    else
                        colorEvent:FireServer("PickingRPNameColor", color)
                    end
                end
            end
            task.wait(0.05)
        end
    end)
end

