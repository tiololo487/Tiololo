local function applyAnimation(animId)
    local char = LocalPlayer.Character
    if not char then return end
    
    local animate = char:FindFirstChild("Animate")
    if not animate then return end
    
    animate.Disabled = true
    
    local animTypes = {"idle", "walk", "run", "jump", "fall", "climb"}
    for _, animType in ipairs(animTypes) do
        local animFolder = animate:FindFirstChild(animType)
        if animFolder then
            for _, anim in ipairs(animFolder:GetChildren()) do
                if anim:IsA("Animation") then
                    anim.AnimationId = "rbxassetid://" .. animId
                end
            end
        end
    end
    
    animate.Disabled = false
    
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if humanoid then
        humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
    end
end

