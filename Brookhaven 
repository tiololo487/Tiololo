local shaderActive = false
local shaderInstances = {}

ShadersTab:Toggle({
    Title = "Shaders v2",
    Default = false,
    Callback = function(state)
        shaderActive = state
        
        if state then
            -- Salvar configurações originais
            getgenv().OriginalLightingSettings = {
                Brightness = Lighting.Brightness,
                ColorShift_Bottom = Lighting.ColorShift_Bottom,
                ColorShift_Top = Lighting.ColorShift_Top,
                OutdoorAmbient = Lighting.OutdoorAmbient,
                ClockTime = Lighting.ClockTime,
                FogColor = Lighting.FogColor,
                FogEnd = Lighting.FogEnd,
                FogStart = Lighting.FogStart,
                ExposureCompensation = Lighting.ExposureCompensation,
                ShadowSoftness = Lighting.ShadowSoftness,
                Ambient = Lighting.Ambient
            }
            
            -- Aplicar novas configurações
            Lighting.Brightness = 2.14
            Lighting.ColorShift_Bottom = Color3.fromRGB(11, 0, 20)
            Lighting.ColorShift_Top = Color3.fromRGB(240, 127, 14)
            Lighting.OutdoorAmbient = Color3.fromRGB(34, 0, 49)
            Lighting.ClockTime = 6.7
            Lighting.FogColor = Color3.fromRGB(94, 76, 106)
            Lighting.FogEnd = 1000
            Lighting.FogStart = 0
            Lighting.ExposureCompensation = 0.24
            Lighting.ShadowSoftness = 0
            Lighting.Ambient = Color3.fromRGB(59, 33, 27)
            
            -- Criar efeitos
            local bloom = Instance.new("BloomEffect")
            bloom.Intensity = 0.1
            bloom.Threshold = 0
            bloom.Size = 100
            bloom.Parent = Lighting
            table.insert(shaderInstances, bloom)
            
            local blur = Instance.new("BlurEffect")
            blur.Size = 2
            blur.Parent = Lighting
            table.insert(shaderInstances, blur)
            
            local colorCorrection = Instance.new("ColorCorrectionEffect")
            colorCorrection.Saturation = 0.05
            colorCorrection.TintColor = Color3.fromRGB(255, 224, 219)
            colorCorrection.Parent = Lighting
            table.insert(shaderInstances, colorCorrection)
            
            local sunRays = Instance.new("SunRaysEffect")
            sunRays.Intensity = 0.05
            sunRays.Parent = Lighting
            table.insert(shaderInstances, sunRays)
            
        else
            -- Restaurar configurações originais
            local original = getgenv().OriginalLightingSettings
            if original then
                Lighting.Brightness = original.Brightness or 1
                Lighting.ColorShift_Bottom = original.ColorShift_Bottom or Color3.new(0, 0, 0)
                Lighting.ColorShift_Top = original.ColorShift_Top or Color3.new(0, 0, 0)
                Lighting.OutdoorAmbient = original.OutdoorAmbient or Color3.new(0, 0, 0)
                Lighting.ClockTime = original.ClockTime or 14
                Lighting.FogColor = original.FogColor or Color3.new(191, 191, 191)
                Lighting.FogEnd = original.FogEnd or 100000
                Lighting.FogStart = original.FogStart or 0
                Lighting.ExposureCompensation = original.ExposureCompensation or 0
                Lighting.ShadowSoftness = original.ShadowSoftness or 0.5
                Lighting.Ambient = original.Ambient or Color3.new(0, 0, 0)
            end
            
            -- Remover efeitos
            for _, instance in ipairs(shaderInstances) do
                instance:Destroy()
            end
            shaderInstances = {}
        end
    end
})

