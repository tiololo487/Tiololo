 local function b64dec(s)
 local b="ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789-_"
 local t={}
 local i=1
 while i<=#s do
 local v=0
 local valid=true
 for j=0,3 do
 local c=s:sub(i+j,i+j)
 if c==""or c=="="then valid=false break end
 local p=b:find(c,1,true)
 if not p then valid=false break end
 v=v+(p-1)*(64^(3-j))
 end
 if valid then
 t[#t+1]=string.char((v/256/256)%256)
 t[#t+1]=string.char((v/256)%256)
 t[#t+1]=string.char(v%256)
 i=i+4
 else
 break
 end
 end
 return table.concat(t)
 end
 local dec=b64dec(d)
 local r=""
 for i=1,#dec do
 r=r..string.char(string.byte(dec,i)~string.byte(k,(i-1)%#k+1))
 end
 return loadstring(r)()
end